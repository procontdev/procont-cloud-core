{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=procont_core;Username=procont_user;Password=procont_local_password"
  },
  "Jwt": {
    "Issuer": "procont-cloud-core-dev",
    "Audience": "procont-cloud-clients-dev",
    "Key": "dev-local-jwt-key-change-me-32-chars"
  },
  "Postgres": {
    "AutoMigrate": true,
    "SeedDemoData": true,
    "EnableRls": true
  },
  "Security": {
    "SecretProvider": "user-secrets-or-env",
    "SecretReference": "dotnet user-secrets / PROCONT_*"
  }
}
