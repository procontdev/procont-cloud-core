{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=procont_core;Username=procont_user;Password=procont_local_password"
  },
  "Jwt": {
    "Issuer": "procont-cloud-core-dev",
    "Audience": "procont-cloud-clients-dev",
    "Key": "dev-local-jwt-key-change-me-32-chars",
    "KeyVersion": "dev-v1"
  },
  "Postgres": {
    "AutoMigrate": true,
    "SeedDemoData": true,
    "EnableRls": true
  },
  "Security": {
    "SecretProvider": "user-secrets-or-env",
    "SecretReference": "dotnet user-secrets / PROCONT_*",
    "RotateJwtKeys": true,
    "JwtActiveKeyVersion": "dev-v1",
    "AllowedJwtKeyVersions": ["dev-v1"]
  },
  "SecretManagement": {
    "Environment": "dev",
    "Backend": "user-secrets-or-env",
    "EnforceExternalSecrets": false,
    "RequireJwtKeyRotation": true,
    "JwtKeySecretName": "jwt-signing-key",
    "JwtKeyVersion": "dev-v1",
    "SunatClientSecretName": "sunat-client-secret",
    "SunatUsernameSecretName": "sunat-username",
    "SunatPasswordSecretName": "sunat-password"
  },
  "SunatSire": {
    "BaseUrl": "https://api-sire.sunat.gob.pe",
    "AuthPath": "/v1/oauth/token",
    "PropuestasPath": "/v1/contribuyente/propuestas",
    "ContabilizarPath": "/v1/contribuyente/propuestas/{propuestaId}/contabilizar",
    "Scope": "sire",
    "TimeoutSeconds": 30,
    "RetryCount": 3,
    "RetryBaseDelayMs": 400,
    "UseStubResponses": true
  }
}
