{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=procont_core;Username=procont_user;Password=procont_local_password"
  },
  "Jwt": {
    "Issuer": "procont-cloud-core",
    "Audience": "procont-cloud-clients",
    "Key": ""
  },
  "Postgres": {
    "AutoMigrate": true,
    "SeedDemoData": true,
    "EnableRls": true
  },
  "Security": {
    "SecretProvider": "environment",
    "SecretReference": "PROCONT_*"
  },
  "TenantResolution": {
    "HeaderName": "X-Tenant-Code",
    "QueryKey": "tenant",
    "AllowSubdomainResolution": true
  },
  "AllowedHosts": "*"
}
